    if len(displacement_bins) > 0:
        displacement_min[col] = np.max(displacement_bins)
        displacement_max[col] = np.min(displacement_bins)
        
time_centers = 0.5 * (x_edges[:-1] + x_edges[1:])


def calculate_delta(a, b):
    return [ai - bi for ai, bi in zip(a, b)]



delta = calculate_delta(displacement_max, displacement_min)


# find the first non-nan value in the min displacement
