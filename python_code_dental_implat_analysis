a= len(time)


@jit
def subtract(a):
    m = max(a)
    result = []
    for x in a:
        result.append(x - m)
    return result


signal_centered = subtract(signal)


signal_centered = np.array(signal_centered)




plt.figure(figsize = (14, 8))
