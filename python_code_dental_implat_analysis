block_size = 100
continuous_counts = []
offset = 0

for i in range(0, len(df), block_size):
    block = df['Axial Counts'].iloc[i:i + block_size].to_numpy()
    if len(block) == 0 or np.all(np.isnan(block)):
        continue
    # Crea blocco continuo aggiungendo offset
    block = block + offset
    continuous_counts.extend(block)
    offset = continuous_counts[-1] + 1  # Aggiorna offset per blocco successivo

# 4. change dataframe
df = df.iloc[:len(continuous_counts)].copy()  # Allinea la lunghezza
